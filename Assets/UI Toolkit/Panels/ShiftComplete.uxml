<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement style="flex-grow: 1;">
        <ui:Label tabindex="-1" text="SHIFT COMPLETE" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Main" class="label-title" style="justify-content: space-around; align-items: center; -unity-text-align: upper-center; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 10%; padding-right: 0; padding-bottom: 0; padding-left: 0%; translate: 0% 5%;" />
        <ui:Label tabindex="-1" text="Health Maintained :" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Sub1" class="label-sub" style="padding-top: 20px; padding-right: 0; padding-bottom: 0; padding-left: 0%; -unity-text-align: upper-center;" />
        <ui:Label tabindex="-1" text="Anomalies Survived  :" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Sub2" class="label-sub" style="padding-top: 5px; padding-right: 0; padding-bottom: 0; padding-left: 0%; -unity-text-align: upper-center;" />
        <ui:Button text="Continue" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Continue" class="label-button" style="padding-left: 0%; padding-bottom: 0; padding-right: 0; padding-top: 3%; margin-left: 0; margin-bottom: 0; margin-right: 0; margin-top: 0; height: 54px; -unity-text-align: upper-center;" />
        <ui:Button text="Main Menu" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Main_Menu" class="label-button" style="height: 34px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0%; -unity-text-align: upper-center;" />
    </ui:VisualElement>
</ui:UXML>
